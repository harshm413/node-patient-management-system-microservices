datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique @db.VarChar(255)
  password String @db.VarChar(255)
  role     String @db.VarChar(50)

  @@map("users")
}
